{
  "compilerOptions": {
    "outDir": "./dist/",
    "noImplicitAny": true,
    "module": "esnext",
    "target": "es5",
    "baseUrl": ".",
    "jsx": "react-jsx",
    "allowJs": true,
    "paths": {
      "*": ["./src/*"]
    },
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true, // позволяет с коммон js работать как с обычными, позволяет работать с модулями которые используем
    "esModuleInterop": true
  },
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS"
    }
  }
}
